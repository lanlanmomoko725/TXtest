# App
APP_SECRET=replace-with-random-secret-at-least-32-chars

# Local MySQL in docker-compose.yml
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DATABASE=skyweb
MYSQL_USER=skyweb
MYSQL_PASSWORD=replace-with-strong-app-password
DATABASE_URL=mysql://skyweb:replace-with-strong-app-password@db:3306/skyweb

# Email verification
EMAIL_AUTH_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-with-app-password
SMTP_FROM="Skyweb <no-reply@example.com>"

# Aliyun CAPTCHA 2.0
# ALIYUN_CAPTCHA_REGION must be cn or sgp. Use ALIYUN_CAPTCHA_ENDPOINT only for a custom or dual-stack endpoint.
# Grant the RAM user AliyunYundunAFSFullAccess; do not use an Alibaba Cloud root account AccessKey.
ALIYUN_CAPTCHA_SCENE_ID=replace-with-scene-id
ALIYUN_CAPTCHA_PREFIX=replace-with-prefix
ALIYUN_CAPTCHA_REGION=cn
# ALIYUN_CAPTCHA_ENDPOINT=captcha-dualstack.cn-shanghai.aliyuncs.com
ALIBABA_CLOUD_ACCESS_KEY_ID=replace-with-ram-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret

# Aliyun SMS verification, PNVS/Dypnsapi SendSmsVerifyCode + CheckSmsVerifyCode
# Grant the RAM user the minimum permissions for dypns:SendSmsVerifyCode and dypns:CheckSmsVerifyCode.
SMS_AUTH_ENABLED=true
ALIYUN_SMS_SIGN_NAME=replace-with-system-sign-name
ALIYUN_SMS_TEMPLATE_CODE=100001
ALIYUN_SMS_TEMPLATE_PARAM={"code":"##code##","min":"5"}
# ALIYUN_SMS_SCHEME_NAME=
# ALIYUN_SMS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_SMS_COUNTRY_CODE=86
ALIYUN_SMS_VALID_TIME_SECONDS=300
ALIYUN_SMS_INTERVAL_SECONDS=60

# Comment safety
# Comma-separated words. Matching comments are rejected before they are saved.
COMMENT_BLOCKLIST=blockedword1,blockedword2
# Optional comma-separated regular expressions. Invalid patterns are ignored.
# COMMENT_BLOCK_PATTERNS=pattern1,pattern2

# Security
COOKIE_SAMESITE=Lax
# Set this only when the browser origin is not the same as the API host.
# ALLOWED_ORIGINS=https://example.com

# Security rollout. Keep recovery disabled until notifications and two reviewers are ready.
UPLOAD_OWNERSHIP_MODE=log
ACCOUNT_RECOVERY_ENABLED=false
PUBLIC_APP_URL=https://example.com
# SMS_NOTICE_WEBHOOK_URL=https://sms-gateway.example.com/security-notice
# SMS_NOTICE_WEBHOOK_SECRET=replace-with-webhook-secret

# Optional future external MySQL/RDS example:
# DATABASE_URL=mysql://skyweb_app:replace-with-strong-app-password@rm-xxxx.mysql.rds.aliyuncs.com:3306/skyweb
# DATABASE_SSL=true
# DATABASE_SSL_CA_PATH=/opt/TXtest/certs/rds-ca.pem
