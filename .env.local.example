# ============================================
# 天象志 - 生产环境配置文件
# ============================================

# ----- 应用配置（必须修改！）-----
# APP_ID: 应用标识，可自定义
APP_ID=tianxiang-app
# APP_SECRET: JWT 签名密钥，务必替换为强随机字符串
# 生成方式: openssl rand -hex 32
APP_SECRET=请替换为随机生成的密钥（至少32位）

# ----- 数据库配置（必须修改！）-----
# DB_PASSWORD 和 DATABASE_URL 中的密码必须完全一致
DB_PASSWORD=tianxiang456
DB_ROOT_PASSWORD=tianxiang123
DATABASE_URL=mysql://tianxiang:tianxiang456@db:3306/tianxiang

# ----- 管理员（可选）-----
# 注册时使用该邮箱将自动获得 admin 角色
# ADMIN_EMAIL=admin@example.com
