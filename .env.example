# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Admin ──────────────────────────────────────────────────────
ADMIN_EMAIL=              # Email for the initial admin account (auto-granted on register)

# Email verification
SMTP_HOST=                # SMTP host
SMTP_PORT=465             # SMTP port
SMTP_USER=                # SMTP username
SMTP_PASS=                # SMTP password/app password
SMTP_FROM=                # Optional From header

# Security
COOKIE_SAMESITE=Lax       # Use None only for explicit cross-site deployments over HTTPS
ALLOWED_ORIGINS=          # Comma-separated extra origins allowed to POST to /api/*
